{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.github.io/enzyme-ai-papers/schemas/weekly.schema.json",
  "title": "Weekly digest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "week",
    "title",
    "date",
    "summary",
    "pick_of_the_week",
    "sections"
  ],
  "properties": {
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "pick_of_the_week": {
      "type": "string"
    },
    "sections": {
      "type": "object"
    },
    "commentary": {
      "type": "object"
    }
  }
}
